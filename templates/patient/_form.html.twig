{{ form_start(form) }}
    <div class="mb-3">
        {{ form_label(form.nom) }}
        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.nom) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.maladie) }}
        {{ form_widget(form.maladie, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.maladie) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.medecin) }}
        {{ form_widget(form.medecin, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.medecin) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.dateVisite) }}
        {{ form_widget(form.dateVisite, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.dateVisite) }}
    </div>
    <button class="btn btn-success">{{ button_label|default('Sauvegarder') }}</button>
{{ form_end(form) }}