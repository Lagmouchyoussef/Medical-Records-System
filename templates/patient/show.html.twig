{% extends 'base.html.twig' %}

{% block title %}Patient{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Patient</h1>

        <table class="table table-striped">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ patient.id }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>{{ patient.nom }}</td>
                </tr>
                <tr>
                    <th>Maladie</th>
                    <td>{{ patient.maladie }}</td>
                </tr>
                <tr>
                    <th>Médecin</th>
                    <td>{{ patient.medecin }}</td>
                </tr>
                <tr>
                    <th>Date de visite</th>
                    <td>{{ patient.dateVisite ? patient.dateVisite|date('Y-m-d') : '' }}</td>
                </tr>
            </tbody>
        </table>

        <a href="{{ path('app_patient_index') }}" class="btn btn-secondary">Retour à la liste</a>

        <a href="{{ path('app_patient_edit', {'id': patient.id}) }}" class="btn btn-warning">Modifier</a>

        {{ include('patient/_delete_form.html.twig') }}
    </div>
{% endblock %}